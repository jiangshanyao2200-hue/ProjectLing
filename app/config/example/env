# Dual-star API configuration
# Each star may use a different Provider, key, base URL, model, and parameter preset.
# Leave PROJECTLING_*_API_KEY / BASE_URL empty to inherit the Provider defaults below.
# Model IDs are relay-specific examples; confirm each star with /models --slot main|executor.
PROJECTLING_MAIN_PROVIDER=gpt
PROJECTLING_MAIN_API_KEY=
PROJECTLING_MAIN_BASE_URL=
PROJECTLING_MAIN_MODEL=gpt-5.6-codex
PROJECTLING_MAIN_PARAMETER_PROFILE=coding
PROJECTLING_MAIN_PARAMS_JSON={}
PROJECTLING_MAIN_TIMEOUT_SECONDS=180
PROJECTLING_MAIN_RETRY_COUNT=3
PROJECTLING_MAIN_ENABLE_SSE=1

PROJECTLING_EXECUTOR_PROVIDER=gemini
PROJECTLING_EXECUTOR_API_KEY=
PROJECTLING_EXECUTOR_BASE_URL=
PROJECTLING_EXECUTOR_MODEL=gemini-3-flash
PROJECTLING_EXECUTOR_PARAMETER_PROFILE=coding
PROJECTLING_EXECUTOR_PARAMS_JSON={}
PROJECTLING_EXECUTOR_TIMEOUT_SECONDS=180
PROJECTLING_EXECUTOR_RETRY_COUNT=3
PROJECTLING_EXECUTOR_ENABLE_SSE=1

